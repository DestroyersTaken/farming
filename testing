-- ============================================================
--  Tycoon Selector | Delta Executor
--  Run this BEFORE the auto farm script
-- ============================================================

local RS = game:GetService("ReplicatedStorage")

-- ──────────────────────────────────────────────────────────
--  SETTINGS
-- ──────────────────────────────────────────────────────────
local TYCOON_REGION = "USA"   -- region to select
local BASE_NUM      = 2        -- base slot number
local DELAY         = 2        -- seconds to wait before firing

-- ──────────────────────────────────────────────────────────
--  HELPERS
-- ──────────────────────────────────────────────────────────
local function getKnitServices()
    return RS
        :WaitForChild("Packages",             9e9)
        :WaitForChild("_Index",               9e9)
        :WaitForChild("sleitnick_knit@1.5.1", 9e9)
        :WaitForChild("knit",                 9e9)
        :WaitForChild("Services",             9e9)
end

local function getTycoonRF()
    return getKnitServices():WaitForChild("TycoonService", 9e9):WaitForChild("RF", 9e9)
end

local function getOfferRF()
    return getKnitServices():WaitForChild("OfferService", 9e9):WaitForChild("RF", 9e9)
end

-- ──────────────────────────────────────────────────────────
--  STEP 1 — SetBase (pick which base slot)
-- ──────────────────────────────────────────────────────────
local function setBase(n)
    local ok, err = pcall(function()
        getTycoonRF():WaitForChild("SetBase", 9e9):InvokeServer(n)
    end)
    print(ok and ("[Selector] ✓ SetBase: " .. n) or ("[Selector] ✗ SetBase failed: " .. tostring(err)))
end

-- ──────────────────────────────────────────────────────────
--  STEP 2 — Select (pick region / tycoon)
-- ──────────────────────────────────────────────────────────
local function selectRegion(region)
    local ok, err = pcall(function()
        getTycoonRF():WaitForChild("Select", 9e9):InvokeServer(region)
    end)
    print(ok and ("[Selector] ✓ Select: " .. region) or ("[Selector] ✗ Select failed: " .. tostring(err)))
end

-- ──────────────────────────────────────────────────────────
--  STEP 3 — AskAboutLastEvent (dismisses Choose Base screen)
-- ──────────────────────────────────────────────────────────
local function dismissChooseBase()
    local ok, err = pcall(function()
        getOfferRF():WaitForChild("AskAboutLastEvent", 9e9):InvokeServer()
    end)
    print(ok and "[Selector] ✓ Choose Base screen dismissed" or ("[Selector] ✗ AskAboutLastEvent failed: " .. tostring(err)))
end

-- ──────────────────────────────────────────────────────────
--  RUN — fire in the order the game expects
-- ──────────────────────────────────────────────────────────
print("[Selector] Waiting", DELAY, "s before selecting…")
task.wait(DELAY)

setBase(BASE_NUM)
task.wait(0.5)

selectRegion(TYCOON_REGION)
task.wait(0.5)

dismissChooseBase()

print("[Selector] Done — tycoon selected and base screen dismissed.")

