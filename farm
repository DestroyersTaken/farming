-- ──────────────────────────────────────────────────────────
--  PHASE 1 — FARM LOOP
-- ──────────────────────────────────────────────────────────
task.spawn(function()
    while running do
        task.wait(0.5)
        -- Wait until tycoon selector has finished and ButtonFolder has had time to appear
        if not selectorDone then
            setStatus("Waiting for tycoon select...")
            task.wait(1) continue
        end
        if not autoFarm or currentPhase ~= 1 then task.wait(1) continue end
        if campActive then setStatus("Camp active - farm paused") task.wait(0.5) continue end

        local tycoon = getTycoon()
        if not tycoon then setStatus("⚠ Tycoon not found") task.wait(3) continue end
        local remote = tycoon:FindFirstChild("RemoteFunction")
        local folder = tycoon:FindFirstChild("ButtonFolder")
        if not remote then setStatus("RemoteFunction missing") task.wait(3) continue end
        if not folder  then setStatus("ButtonFolder missing")  task.wait(3) continue end

        -- Buy Start button first if present (initialises tycoon on first run)
        if folder:FindFirstChild("Start") then
            print("[Phase1] Found Start button - buying")
            setStatus("Buying Start button...")
            fireRemote(remote, "Start")
            task.wait(BUY_DELAY + 1)
        end

        local rebirths = getRebirths()
        if rebirths >= REBIRTH_TARGET then
            setStatus("✓ Phase 1 done! Switching to Tycoon 2…")
            print("[Phase1] 5 rebirths reached — switching to Phase 2")
            task.wait(2)
            currentPhase = 2
            selectTycoon(2)
            task.wait(3)
            continue
        end

        -- Buy loop: priority first, workers if no priority, re-scan each pass
        local emptyCount = 0
        while running and autoFarm and not campActive and emptyCount < EMPTY_PASSES do
            local hasPriority = false
            for _, name in ipairs(PHASE1_PRIORITY) do
                if folder:FindFirstChild(name) then hasPriority = true break end
            end
            local hasWorker = false
            for _, b in ipairs(folder:GetChildren()) do
                if b.Name:lower():find("worker") then hasWorker = true break end
            end

            if not hasPriority and not hasWorker then
                emptyCount = emptyCount + 1
                setStatus("Waiting for unlocks... ("..emptyCount.."/"..EMPTY_PASSES..")")
                task.wait(1.5)
            else
                emptyCount = 0
                if hasPriority then
                    setStatus("Buying priority buttons...")
                    for _, name in ipairs(PHASE1_PRIORITY) do
                        if not running or not autoFarm or campActive then break end
                        if folder:FindFirstChild(name) then
                            smartBuy(remote, folder, name)
                        end
                    end
                else
                    setStatus("Buying workers...")
                    for _, b in ipairs(folder:GetChildren()) do
                        if not running or not autoFarm or campActive then break end
                        if b.Name:lower():find("worker") then
                            smartBuy(remote, folder, b.Name)
                        end
                    end
                end
                task.wait(1)
            end
        end

        -- Worker status
        local hasW = false
        for _, b in ipairs(folder:GetChildren()) do
            if b.Name:lower():find("worker") then hasW = true break end
        end
        allWorkersDone = not hasW
        workerLbl.Text = allWorkersDone and "Workers: ✓ All bought" or "Workers: buying…"
        workerLbl.TextColor3 = allWorkersDone and Color3.fromRGB(85,222,85) or Color3.fromRGB(255,198,65)

        -- Rebirth check — trigger at $200k regardless of worker status
        -- (workers that need rebirths to unlock will remain in folder, that's fine)
        local money = getMoney()
        print(string.format("[Rebirth Check] money=%d | need=%d", money, MONEY_TO_REBIRTH))

        if money >= MONEY_TO_REBIRTH then
            local rebirthRemote = tycoon:WaitForChild("Rebirth", 10)
            if not rebirthRemote then
                warn("[AutoFarm] Rebirth remote not found!")
            else
                local rebirthDone = false
                while running and autoFarm and not rebirthDone do
                    setStatus("💫 Attempting rebirth…")
                    local ok, result = pcall(function() return rebirthRemote:InvokeServer() end)
                    print("[AutoFarm] Rebirth result:", ok, result)
                    if ok and result ~= false then
                        print("[AutoFarm] ✓ Rebirth successful!")
                        rebirthDone = true
                        task.wait(5)
                    else
                        warn("[AutoFarm] Rebirth false — buying one pass all buttons…")
                        local btns = folder:GetChildren()
                        setStatus("Buying all buttons… ("..#btns.." found)")
                        for _, b in ipairs(btns) do
                            if not running or not autoFarm then break end
                            fireRemote(remote, b.Name); task.wait(BUY_DELAY)
                        end
                        while running and autoFarm and getMoney() < MONEY_TO_REBIRTH do
                            task.wait(2); teleportToCollector()
                            setStatus("Farming $200k… $"..tostring(getMoney()).." / $200,000")
                        end
                        print("[AutoFarm] $200k hit — retrying rebirth…")
                    end
                end
            end
            task.wait(2)
        else
            setStatus("Farming $200k… $"..tostring(money).." / $200,000")
        end
    end
end)

-- ──────────────────────────────────────────────────────────
--  PHASE 2 — AFK FARM LOOP
-- ──────────────────────────────────────────────────────────
task.spawn(function()
    local lastAfkTeleport = 0
    while running do
        task.wait(1)
        if not autoFarm or currentPhase ~= 2 then continue end
        if campActive then setStatus("⚠️ Clearing camp… (farm paused)") continue end

        local tycoon = getTycoon()
        if not tycoon then setStatus("⚠ Tycoon not found (P2)") task.wait(3) continue end
        local remote = tycoon:FindFirstChild("RemoteFunction")
        local folder = tycoon:FindFirstChild("ButtonFolder")
        if not remote or not folder then task.wait(3) continue end

        local afkPart = getAfkPart()

        if afkPart then
            -- AFK mode — teleport every AFK_INTERVAL seconds
            phase2StopHit = true
            afkLbl.Text = "🎯 AFK Mode active"
            local now = tick()
            if now - lastAfkTeleport >= AFK_INTERVAL then
                lastAfkTeleport = now
                teleportTo(afkPart)
                setStatus("🎯 AFK teleport → AutoEquipWeapon")
                print("[Phase2] AFK teleport to AutoEquipWeapon")
            else
                local remaining = math.ceil(AFK_INTERVAL - (now - lastAfkTeleport))
                setStatus("🎯 AFK — next teleport in "..remaining.."s")
            end
        else
            -- AutoEquipWeapon not found yet — buy Phase 2 buttons
            afkLbl.Text = ""
            if phase2StopHit then
                -- Already bought Manual — just wait for AFK part to appear
                setStatus("Waiting for AFK station to spawn…")
                task.wait(3)
                continue
            end

            -- Check for Phase 2 priority buttons
            local hasPriority = false
            for _, name in ipairs(PHASE2_PRIORITY) do
                if name == PHASE2_STOP_AT then
                    -- If Manual itself is in folder, buy it then stop
                    if folder:FindFirstChild(name) then
                        setStatus("Buying final button: "..name)
                        fireRemote(remote, name)
                        task.wait(BUY_DELAY)
                        phase2StopHit = true
                        print("[Phase2] Manual bought — stopping button buying")
                    end
                    break
                end
                if folder:FindFirstChild(name) then hasPriority = true break end
            end

            if hasPriority and not phase2StopHit then
                setStatus("Phase 2: buying priority buttons…")
                for _, name in ipairs(PHASE2_PRIORITY) do
                    if not running or not autoFarm or campActive then break end
                    if name == PHASE2_STOP_AT then
                        if folder:FindFirstChild(name) then
                            fireRemote(remote, name); task.wait(BUY_DELAY)
                            phase2StopHit = true
                        end
                        break
                    end
                    if folder:FindFirstChild(name) and not PHASE2_BLACKLIST[name] then
                        fireRemote(remote, name); task.wait(BUY_DELAY)
                    end
                end
                task.wait(1)
            elseif not phase2StopHit then
                -- No priority buttons — buy anything not blacklisted until AFK part appears
                setStatus("Phase 2: buying all available…")
                for _, b in ipairs(folder:GetChildren()) do
                    if not running or not autoFarm or campActive then break end
                    if not PHASE2_BLACKLIST[b.Name] and b.Name ~= PHASE2_STOP_AT then
                        fireRemote(remote, b.Name); task.wait(BUY_DELAY)
                    end
                end
                -- Check for Manual
                if folder:FindFirstChild(PHASE2_STOP_AT) then
                    fireRemote(remote, PHASE2_STOP_AT)
                    task.wait(BUY_DELAY)
                    phase2StopHit = true
                end
                task.wait(1)
            end
        end
