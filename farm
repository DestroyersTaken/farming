local function mkLabel(y, txt, col)
    local l = Instance.new("TextLabel", frame)
    l.Size               = UDim2.new(1, -20, 0, 20)
    l.Position           = UDim2.new(0, 10, 0, y)
    l.BackgroundTransparency = 1
    l.Text               = txt
    l.TextColor3         = col or Color3.fromRGB(175, 170, 210)
    l.TextSize           = 12
    l.Font               = Enum.Font.Gotham
    l.TextXAlignment     = Enum.TextXAlignment.Left
    return l
end

local statusLbl  = mkLabel(44,  "Status: Starting…",        Color3.fromRGB(175, 170, 210))
local moneyLbl   = mkLabel(66,  "Money: $0",                 Color3.fromRGB(255, 218, 85))
local rebirthLbl = mkLabel(88,  "Rebirths: 0 / 5",           Color3.fromRGB(110, 220, 135))
local workerLbl  = mkLabel(110, "Workers: pending…",          Color3.fromRGB(175, 170, 210))

-- Toggle button
local togBtn = Instance.new("TextButton", frame)
togBtn.Size             = UDim2.new(1, -20, 0, 36)
togBtn.Position         = UDim2.new(0, 10, 0, 138)
togBtn.BackgroundColor3 = Color3.fromRGB(75, 52, 180)
togBtn.BorderSizePixel  = 0
