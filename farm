local function selectTycoon(baseNum)
    print("[Selector] Selecting tycoon slot", baseNum)
    pcall(function() getKnitRF("TycoonService"):WaitForChild("SetBase",9e9):InvokeServer(baseNum) end)
    task.wait(0.5)
    pcall(function() getKnitRF("TycoonService"):WaitForChild("Select",9e9):InvokeServer(TYCOON_REGION) end)
    task.wait(0.5)
    pcall(function() getKnitRF("OfferService"):WaitForChild("AskAboutLastEvent",9e9):InvokeServer() end)
    print("[Selector] Done — slot", baseNum, "selected")
end

