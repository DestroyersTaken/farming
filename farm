-- ──────────────────────────────────────────────────────────
local function parseCash(raw)
    raw = tostring(raw):gsub("%$",""):gsub(",",""):gsub("%s+","")
    local num, suffix = raw:match("^([%d%.]+)([KkMmBbTt]?)$")
    if num then
        local n = tonumber(num) or 0
        local mult = ({K=1e3,M=1e6,B=1e9,T=1e12})[suffix and suffix:upper()] or 1
        return math.floor(n * mult)
    end
    return math.floor(tonumber(raw) or 0)
end

local function getMoney()
    if not leaderstats then return 0 end
    local v = leaderstats:FindFirstChild("Cash")
    if not v then return 0 end
    return parseCash(v.Value)
end

local function getRebirths()
    if not leaderstats then return 0 end
    local v = leaderstats:FindFirstChild("Rebirths")
    return math.floor(tonumber(v and v.Value) or 0)
end

local function getTycoon()
    local pt = workspace:FindFirstChild("PlayerTycoons")
    if not pt then return nil end
    return pt:FindFirstChild(username)
end

local function teleportTo(part)
    local hrp = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp or not part then return end
    local cf
    if part:IsA("BasePart") then
        cf = part.CFrame
    else
        local p = part:FindFirstChildWhichIsA("BasePart", true)
        cf = p and p.CFrame
    end
    if cf then hrp.CFrame = cf + Vector3.new(0, 4, 0) end
end

local function teleportToCollector()
    local tycoon = getTycoon()
    if not tycoon then return end
    local sg  = tycoon:FindFirstChild("Models") and tycoon.Models:FindFirstChild("StarterGiver")
    local btn = sg and sg:FindFirstChild("CollectButton")
    teleportTo(btn)
end

local function fireRemote(remote, btnName)
    print("[Buy] InvokeServer(BuyButton, " .. btnName .. ")")
    local ok, err = pcall(function() remote:InvokeServer("BuyButton", btnName) end)
    if not ok then warn("[Buy] Error: " .. tostring(err)) end
end

-- Get cash price from button BillboardGui (Phase 1 only)
local function getButtonPrice(btnFolder)
    local ok, result = pcall(function()
        local b   = btnFolder:FindFirstChild("Button")
        local gui = b and b:FindFirstChild("BillboardGui")
        local frm = gui and gui:FindFirstChild("Frame")
        local lbl = frm and frm:FindFirstChild("Price")
        if lbl then return parseCash(lbl.ContentText) end
        return nil
    end)
    return ok and result or nil
end

-- Get rebirth requirement from button BillboardGui (Phase 1 only)
-- Handles: "1 REBIRTH", "Rebirth 5", "2 REBIRTH", etc.
local function getButtonRebirth(btnFolder)
    local ok, result = pcall(function()
        local b   = btnFolder:FindFirstChild("Button")
        local gui = b and b:FindFirstChild("BillboardGui")
        local frm = gui and gui:FindFirstChild("Frame")
        local lbl = frm and frm:FindFirstChild("Rebirth")
        if lbl then
            local n = lbl.ContentText:match("%d+")
            return n and tonumber(n) or nil
        end
        return nil
    end)
    return ok and result or nil
end

-- Phase 1 smart buy: checks price, waits for money, then checks rebirth req on failure
local function smartBuy(remote, folder, btnName)
    local btnObj = folder:FindFirstChild(btnName)
    if not btnObj then return end  -- already gone

    local price = getButtonPrice(btnObj)
    if price and price > 0 then
        if getMoney() < price then
            setStatus("Saving for " .. btnName .. "… $" .. tostring(getMoney()) .. " / $" .. tostring(price))
            while running and autoFarm and getMoney() < price do
                task.wait(2)
                teleportToCollector()
            end
        end
    end

    -- Attempt buy
    fireRemote(remote, btnName)
    task.wait(BUY_DELAY)

    -- If button is still in folder after buying, it failed
    if folder:FindFirstChild(btnName) then
        local rebirthReq = getButtonRebirth(btnObj)
        local currentReb = getRebirths()
        if rebirthReq and currentReb < rebirthReq then
            print(string.format("[Skip] %s needs %d rebirths, have %d", btnName, rebirthReq, currentReb))
            setStatus("Can't buy " .. btnName .. " — need " .. rebirthReq .. " rebirths")
        end
    end
end

local function getAfkPart()
    local tycoon = getTycoon()
    if not tycoon then return nil end
    local m = tycoon:FindFirstChild("Models")
    if not m then return nil end
    local afk = m:FindFirstChild("AfkShooting")
    if not afk then return nil end
    local mw = afk:FindFirstChild("ManualWorker")
    if not mw then return nil end
    local sfm = mw:FindFirstChild("ShootForMoney")
    if not sfm then return nil end
    return sfm:FindFirstChild("AutoEquipWeapon")
end

