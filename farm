-- ──────────────────────────────────────
--  STATE
-- ──────────────────────────────────────
local autoFarm        = true
local allWorkersDone  = false
local phase1Complete  = false

-- ──────────────────────────────────────
--  HELPERS
-- ──────────────────────────────────────
local function getTycoon()
    local pt = workspace:FindFirstChild("PlayerTycoons")
    if not pt then return nil end
    return pt:FindFirstChild(username)
end

local function getMoney()
    if leaderstats then
        local cash = leaderstats:FindFirstChild("Cash")
        if cash then return cash.Value end
    end
    return 0
end

local function getRebirths()
    if leaderstats then
        local rb = leaderstats:FindFirstChild("Rebirths")
        if rb then return rb.Value end
    end
    return 0
end

local function teleportToCollector()
    local tycoon = getTycoon()
    if not tycoon then print("[Collect] tycoon not found") return end
    local models = tycoon:FindFirstChild("Models")
    if not models then print("[Collect] Models folder not found") return end
    local starterGiver = models:FindFirstChild("StarterGiver")
    if not starterGiver then print("[Collect] StarterGiver not found") return end
    local collectBtn = starterGiver:FindFirstChild("CollectButton")
    if not collectBtn then print("[Collect] CollectButton not found") return end
    local hrp = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    hrp.CFrame = collectBtn.CFrame + Vector3.new(0, 5, 0)
end

local function buyBtn(remote, name)
    pcall(function()
        remote:InvokeServer("BuyButton", name)
    end)
end

local function hasWorkerButtons(folder)
    for _, b in ipairs(folder:GetChildren()) do
        if b.Name:lower():find("worker") then return true end
    end
    return false
end

