-- ============================================================
--  Tycoon Auto Farm | Delta Executor
--  Phase 1: Buy all buttons → unlock workers → rebirth x5
-- ============================================================

local Players      = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local localPlayer  = Players.LocalPlayer
local username     = localPlayer.Name

-- ──────────────────────────────────────────────────────────
--  SETTINGS
-- ──────────────────────────────────────────────────────────
local BUY_DELAY        = 0.5   -- seconds between button purchases
local COLLECT_INTERVAL = 2     -- seconds between money collections
local REBIRTH_TARGET   = 5     -- phase 1 goal
local MONEY_TO_REBIRTH = 200000
local EMPTY_PASSES     = 3     -- how many consecutive empty-folder checks before considering all bought

-- Priority list: buy these in order first before everything else
local PRIORITY_BUTTONS = {
    "Worker_1","Worker_2",
    "NewBase_FirstFloor_SGwall3","NewBase_FirstFloor_SGWindow1","NewBase_FirstFloor_SGLaserDoor1",
    "NewBase_FirstFloor_SGWall2","NewBase_FirstFloor_SGWall4","NewBase_FirstFloor_SGWindow2",
    "NewBase_FirstFloor_SGWall1","NewBase_FirstFloor_SGLaserDoor2",
    "NewBase_FirstFloor_Wall1","NewBase_FirstFloor_Wall5","NewBase_FirstFloor_Wall4",
    "NewBase_FirstFloor_Wall8","NewBase_FirstFloor_Wall3","NewBase_FirstFloor_Wall7",
    "NewBase_FirstFloor_Wall2","NewBase_FirstFloor_Wall6","NewBase_FirstFloor_Windows",
    "NewBase_FirstFloor_Path1","NewBase_FirstFloor_Door2","NewBase_FirstFloor_Door1",
    "NewBase_FirstFloor_LaserDoor2","NewBase_FirstFloor_LaserDoor1",
    "NewBase_FirstFloor_RoofBeams","NewBase_FirstFloor_Roof","MapTable",
    "NewBase_FirstFloor_RoofLights","NewBase_FirstFloor_SGSigns",
    "Weapon1","Melee1","Spinner",
}

-- ──────────────────────────────────────────────────────────
--  STATE
-- ──────────────────────────────────────────────────────────
local autoFarm       = true
local allWorkersDone = false
local phase1Done     = false

-- ──────────────────────────────────────────────────────────
--  WAIT FOR LEADERSTATS
-- ──────────────────────────────────────────────────────────
local leaderstats = localPlayer:WaitForChild("leaderstats", 20)
if leaderstats then
    local cashVal     = leaderstats:FindFirstChild("Cash")
    local rebirthVal  = leaderstats:FindFirstChild("Rebirths")
    print("[AutoFarm] leaderstats OK |",
        "Cash =", cashVal and tostring(cashVal.Value) or "nil",
        "| Rebirths =", rebirthVal and tostring(rebirthVal.Value) or "nil")
else
    warn("[AutoFarm] leaderstats not found – money/rebirth will show 0")
end

-- ──────────────────────────────────────────────────────────
--  HELPERS
-- ──────────────────────────────────────────────────────────
local function getMoney()
    if not leaderstats then return 0 end
    local v = leaderstats:FindFirstChild("Cash")
    if not v then return 0 end
    -- Strip commas in case the value is formatted like "1,500"
    local raw = tostring(v.Value):gsub(",", "")
    return math.floor(tonumber(raw) or 0)
end

local function getRebirths()
    if not leaderstats then return 0 end
    local v = leaderstats:FindFirstChild("Rebirths")
    return math.floor(tonumber(v and v.Value) or 0)
end

local function getTycoon()
    local pt = workspace:FindFirstChild("PlayerTycoons")
    if not pt then return nil end
    return pt:FindFirstChild(username)
end

local function teleportToCollector()
    local tycoon = getTycoon()
    if not tycoon then return end
    local models      = tycoon:FindFirstChild("Models")
    local starterGiver = models and models:FindFirstChild("StarterGiver")
    local collectBtn  = starterGiver and starterGiver:FindFirstChild("CollectButton")
    local hrp         = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
    if collectBtn and hrp then
        hrp.CFrame = collectBtn.CFrame + Vector3.new(0, 5, 0)
    end
end

local function fireRemote(remote, btnName)
    print("[Buy] InvokeServer(BuyButton, " .. btnName .. ")")
    local ok, err = pcall(function()
        remote:InvokeServer("BuyButton", btnName)
    end)
    if not ok then warn("[Buy] Error on " .. btnName .. ": " .. tostring(err)) end
end

-- ──────────────────────────────────────────────────────────
--  GUI
-- ──────────────────────────────────────────────────────────
if localPlayer.PlayerGui:FindFirstChild("TycoonFarmGUI") then
    localPlayer.PlayerGui.TycoonFarmGUI:Destroy()
end

