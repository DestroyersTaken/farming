-- ──────────────────────────────────────
--  COLLECT LOOP (parallel)
-- ──────────────────────────────────────
task.spawn(function()
    while true do
        task.wait(COLLECT_INTERVAL)
        if autoFarm then
            teleportToCollector()
        end
    end
end)

-- ──────────────────────────────────────
--  MAIN FARM LOOP
-- ──────────────────────────────────────
task.spawn(function()
    while true do
        task.wait(0.2)

        if not autoFarm then
            setStatus("Paused")
            task.wait(1)
            continue
        end

        local tycoon = getTycoon()
        if not tycoon then
            setStatus("⚠ Tycoon not found")
            print("[AutoFarm] PlayerTycoons/" .. username .. " not found yet")
            task.wait(3)
            continue
        end

        local remote = tycoon:FindFirstChild("RemoteFunction")
        local folder = tycoon:FindFirstChild("ButtonFolder")
        if not remote then
            setStatus("⚠ RemoteFunction missing")
            print("[AutoFarm] RemoteFunction not found in tycoon")
            task.wait(3)
            continue
        end
        if not folder then
            setStatus("⚠ ButtonFolder missing")
            print("[AutoFarm] ButtonFolder not found in tycoon")
            task.wait(3)
            continue
        end
        print("[AutoFarm] Tycoon OK — buttons:", #folder:GetChildren())

        -- Update HUD
        local money    = getMoney()
        local rebirths = getRebirths()
        moneyLbl.Text   = "Money: $" .. string.format("%d", money)
        rebirthLbl.Text = "Rebirths: " .. rebirths .. " / " .. REBIRTH_TARGET

        -- Phase 1 complete check
        if rebirths >= REBIRTH_TARGET then
            phase1Complete  = true
            autoFarm        = false
            togBtn.Text             = "▶  Auto Farm: OFF"
            togBtn.BackgroundColor3 = Color3.fromRGB(120,40,40)
            setStatus("🎉 Phase 1 Complete!")
            phaseLbl.Text   = "🎉 Phase 1 Done! (5 Rebirths)"
            phaseLbl.TextColor3 = Color3.fromRGB(255,215,0)
            print("[AutoFarm] 🎉 Phase 1 complete — " .. REBIRTH_TARGET .. " rebirths reached!")
            continue
        end

        -- ── 1. Priority buttons (in order) ──
        setStatus("Buying priority buttons…")
        for _, name in ipairs(PRIORITY_BUTTONS) do
            if not autoFarm then break end
            if folder:FindFirstChild(name) then
                buyBtn(remote, name)
                task.wait(BUY_DELAY)
            end
        end

        -- ── 2. Any remaining Worker buttons ──
        setStatus("Buying extra workers…")
        for _, b in ipairs(folder:GetChildren()) do
            if not autoFarm then break end
            if b.Name:lower():find("worker") then
                buyBtn(remote, b.Name)
                task.wait(BUY_DELAY)
            end
        end

        -- ── 3. Worker status ──
        allWorkersDone = not hasWorkerButtons(folder)
        if allWorkersDone then
            workerLbl.Text      = "Workers: ✓ All bought"
            workerLbl.TextColor3 = Color3.fromRGB(90,230,90)
        else
            workerLbl.Text      = "Workers: buying…"
            workerLbl.TextColor3 = Color3.fromRGB(255,200,70)
        end

        -- ── 4. Buy everything else ──
        setStatus("Buying remaining buttons…")
        for _, b in ipairs(folder:GetChildren()) do
            if not autoFarm then break end
            buyBtn(remote, b.Name)
            task.wait(BUY_DELAY)
        end

        -- ── 5. Rebirth check ──
        money    = getMoney()
        rebirths = getRebirths()
        moneyLbl.Text   = "Money: $" .. string.format("%d", money)
        rebirthLbl.Text = "Rebirths: " .. rebirths .. " / " .. REBIRTH_TARGET

        if allWorkersDone and money >= MONEY_TO_REBIRTH then
            print(string.format("[AutoFarm] ✓ $%d reached — all workers bought! Rebirthing (%d/%d)…",
                money, rebirths + 1, REBIRTH_TARGET))
            setStatus("💫 Rebirthing!")
            pcall(function()
                workspace.PlayerTycoons[username].Rebirth:InvokeServer()
            end)
            task.wait(4)
        elseif allWorkersDone then
            setStatus(string.format("Farming $200k… ($%d / $200,000)", math.floor(money)))
        else
            setStatus("Unlocking workers…")
        end
    end
end)

print("[AutoFarm] Loaded for: " .. username)
