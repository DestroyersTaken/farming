titleLbl.Position           = UDim2.new(0, 12, 0, 0)
titleLbl.BackgroundTransparency = 1
titleLbl.Text               = "🏆  Tycoon Auto Farm"
titleLbl.TextColor3         = Color3.fromRGB(205, 180, 255)
