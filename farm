togBtn.TextSize         = 13
togBtn.Font             = Enum.Font.GothamBold
Instance.new("UICorner", togBtn).CornerRadius = UDim.new(0, 8)

local phaseLbl = mkLabel(184, "Phase 1: Farm 5 Rebirths", Color3.fromRGB(150, 130, 255))

local function setStatus(s) statusLbl.Text = "Status: " .. s end

togBtn.MouseButton1Click:Connect(function()
    autoFarm = not autoFarm
    if autoFarm then
        togBtn.Text             = "⏸  Auto Farm: ON"
        togBtn.BackgroundColor3 = Color3.fromRGB(75, 52, 180)
    else
        togBtn.Text             = "▶  Auto Farm: OFF"
        togBtn.BackgroundColor3 = Color3.fromRGB(115, 38, 38)
    end
end)
togBtn.MouseEnter:Connect(function()
    TweenService:Create(togBtn, TweenInfo.new(.12), {
        BackgroundColor3 = autoFarm and Color3.fromRGB(95, 70, 205) or Color3.fromRGB(140, 50, 50)
    }):Play()
end)
togBtn.MouseLeave:Connect(function()
    TweenService:Create(togBtn, TweenInfo.new(.12), {
        BackgroundColor3 = autoFarm and Color3.fromRGB(75, 52, 180) or Color3.fromRGB(115, 38, 38)
    }):Play()
end)

-- ──────────────────────────────────────────────────────────
--  HUD UPDATE LOOP  (every 0.5s, independent of buy loop)
-- ──────────────────────────────────────────────────────────
task.spawn(function()
    local debugTick = 0
    while true do
        task.wait(0.5)
        local m = getMoney()
        local r = getRebirths()
        moneyLbl.Text   = "Money: $" .. tostring(m)
        rebirthLbl.Text = "Rebirths: " .. tostring(r) .. " / " .. tostring(REBIRTH_TARGET)

        -- Debug print every 5 seconds so you can verify raw Cash value
        debugTick = debugTick + 0.5
        if debugTick >= 5 then
            debugTick = 0
            if leaderstats then
                local cashObj = leaderstats:FindFirstChild("Cash")
                print("[Debug] Raw Cash.Value =", cashObj and tostring(cashObj.Value) or "NIL",
                    "| parsed =", m,
                    "| Rebirths =", r,
                    "| allWorkersDone =", allWorkersDone)
            end
        end
    end
end)

-- ──────────────────────────────────────────────────────────
--  COLLECT LOOP  (every COLLECT_INTERVAL seconds)
-- ──────────────────────────────────────────────────────────
task.spawn(function()
    while true do
        task.wait(COLLECT_INTERVAL)
        if autoFarm then
            teleportToCollector()
        end
    end
end)

-- ──────────────────────────────────────────────────────────
--  MAIN FARM LOOP
-- ──────────────────────────────────────────────────────────
task.spawn(function()
    while true do
        task.wait(0.5)

        if not autoFarm then
            setStatus("Paused")
            task.wait(1)
            continue
        end

        if phase1Done then
            setStatus("🎉 Phase 1 Complete!")
            task.wait(5)
            continue
        end

        -- Find tycoon
        local tycoon = getTycoon()
        if not tycoon then
            setStatus("⚠ Tycoon not found (PlayerTycoons/" .. username .. ")")
            task.wait(3)
            continue
        end

        local remote = tycoon:FindFirstChild("RemoteFunction")
        local folder = tycoon:FindFirstChild("ButtonFolder")

        if not remote then setStatus("⚠ RemoteFunction missing") task.wait(3) continue end
        if not folder then setStatus("⚠ ButtonFolder missing")   task.wait(3) continue end

        -- Phase 1 complete?
        local rebirths = getRebirths()
        if rebirths >= REBIRTH_TARGET then
            phase1Done = true
            autoFarm   = false
            togBtn.Text             = "▶  Auto Farm: OFF"
            togBtn.BackgroundColor3 = Color3.fromRGB(115, 38, 38)
            phaseLbl.Text           = "🎉 Phase 1 Done! (" .. REBIRTH_TARGET .. " Rebirths)"
            phaseLbl.TextColor3     = Color3.fromRGB(255, 215, 0)
            print("[AutoFarm] 🎉 Phase 1 complete — " .. REBIRTH_TARGET .. " rebirths done!")
            continue
        end

        -- ── BUY LOOP ──────────────────────────────────────────
        -- Only buy PRIORITY buttons and WORKER buttons.
        -- Priority always goes first. Workers only when no priority buttons remain.
        -- Loop keeps re-scanning because buying one button unlocks the next.
        -- Exit when neither a priority nor a worker button is found for EMPTY_PASSES attempts.
        local emptyCount = 0
        while autoFarm and emptyCount < EMPTY_PASSES do

            -- Check what's available right now
            local hasPriority = false
            for _, name in ipairs(PRIORITY_BUTTONS) do
                if folder:FindFirstChild(name) then
                    hasPriority = true
                    break
                end
            end

            local hasWorker = false
            for _, b in ipairs(folder:GetChildren()) do
                if b.Name:lower():find("worker") then
                    hasWorker = true
                    break
                end
            end

            if not hasPriority and not hasWorker then
                -- Nothing we care about — wait for new buttons to unlock
                emptyCount = emptyCount + 1
                setStatus("Waiting for unlocks… (" .. emptyCount .. "/" .. EMPTY_PASSES .. ")")
                task.wait(1.5)
            else
                emptyCount = 0  -- something found, reset streak

                if hasPriority then
                    -- Buy priority buttons in order
                    setStatus("Buying priority buttons…")
                    for _, name in ipairs(PRIORITY_BUTTONS) do
                        if not autoFarm then break end
                        if folder:FindFirstChild(name) then
                            fireRemote(remote, name)
                            task.wait(BUY_DELAY)
                        end
                    end
                else
                    -- No priority buttons left — buy workers
                    setStatus("Buying workers…")
                    for _, b in ipairs(folder:GetChildren()) do
                        if not autoFarm then break end
                        if b.Name:lower():find("worker") then
                            fireRemote(remote, b.Name)
                            task.wait(BUY_DELAY)
                        end
                    end
                end

                -- Pause so server can spawn newly unlocked buttons
                task.wait(1)
            end
        end

        -- ── Worker status ──────────────────────────────────────
        local hasWorkers = false
        for _, b in ipairs(folder:GetChildren()) do
            if b.Name:lower():find("worker") then hasWorkers = true break end
        end
        allWorkersDone = not hasWorkers
        if allWorkersDone then
            workerLbl.Text       = "Workers: ✓ All bought"
            workerLbl.TextColor3 = Color3.fromRGB(85, 222, 85)
        else
            workerLbl.Text       = "Workers: buying…"
            workerLbl.TextColor3 = Color3.fromRGB(255, 198, 65)
        end

        -- ── Rebirth check ──────────────────────────────────────
        local money = getMoney()
        rebirths    = getRebirths()

        print(string.format("[Rebirth Check] money=%d | allWorkersDone=%s | need=%d",
            money, tostring(allWorkersDone), MONEY_TO_REBIRTH))

        if allWorkersDone and money >= MONEY_TO_REBIRTH then
            print(string.format("[AutoFarm] ✓ $%d reached + workers done! Rebirthing (%d/%d)…",
                money, rebirths + 1, REBIRTH_TARGET))
            setStatus("💫 Rebirthing!")
            local ok, err = pcall(function()
                workspace.PlayerTycoons[username].Rebirth:InvokeServer()
            end)
            if ok then
                print("[AutoFarm] ✓ Rebirth fired successfully")
            else
                warn("[AutoFarm] ✗ Rebirth failed: " .. tostring(err))
            end
            task.wait(5)
        elseif allWorkersDone then
            setStatus("Farming $200k… $" .. tostring(money) .. " / $200,000")
        else
            setStatus("Unlocking workers…")
        end
    end
end)

print("[AutoFarm] Script loaded for: " .. username)
