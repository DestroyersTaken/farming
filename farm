-- ──────────────────────────────────────────────────────────
--  MAIN FARM LOOP
-- ──────────────────────────────────────────────────────────
task.spawn(function()
    while running do
        task.wait(1)
        if not autoFarm then continue end
        if not selectorDone then setStatus("Waiting for tycoon select...") continue end
        if campActive then setStatus("Camp active - farm paused") continue end
        if afkMode then continue end  -- AFK loop handles this

        local tycoon = getTycoon()
        if not tycoon then setStatus("Tycoon not found") task.wait(3) continue end
        local remote = tycoon:FindFirstChild("RemoteFunction")
        local folder = tycoon:FindFirstChild("ButtonFolder")
        if not remote then setStatus("RemoteFunction missing") task.wait(3) continue end
        if not folder  then setStatus("ButtonFolder missing")  task.wait(3) continue end

        -- ── Buy Start button if present (first run) ──────
        if folder:FindFirstChild("Start") then
            print("[Farm] Buying Start button")
            setStatus("Buying Start button...")
            fireRemote(remote, "Start")
            task.wait(BUY_DELAY + 1)
        end

        local rebirths = getRebirths()

        -- ── Rebirth check: only rebirth if at 0 ──────────
        if rebirths < 1 then
            -- Need 1 rebirth first
            -- Buy priority/workers with rescan until $150k reached
            local emptyPasses = 0
            while running and autoFarm and not campActive and emptyPasses < EMPTY_PASSES do
                if getMoney() >= MONEY_TO_REBIRTH then break end

                local hasPriority = false
                for _, name in ipairs(PRIORITY) do
                    if folder:FindFirstChild(name) then hasPriority = true break end
                end
                local hasWorker = false
                for _, b in ipairs(folder:GetChildren()) do
                    if b.Name:lower():find("worker") then hasWorker = true break end
                end

                if not hasPriority and not hasWorker then
                    emptyPasses = emptyPasses + 1
                    setStatus("Waiting for buttons... (" .. emptyPasses .. "/" .. EMPTY_PASSES .. ")")
                    task.wait(2)
                else
                    emptyPasses = 0
                    if hasPriority then
                        setStatus("Buying priority buttons...")
                        for _, name in ipairs(PRIORITY) do
                            if not running or not autoFarm or campActive then break end
                            if getMoney() >= MONEY_TO_REBIRTH then break end
                            if folder:FindFirstChild(name) then
                                smartBuy(remote, folder, name)
                            end
                        end
                    else
                        setStatus("Buying workers...")
                        for _, b in ipairs(folder:GetChildren()) do
                            if not running or not autoFarm or campActive then break end
                            if getMoney() >= MONEY_TO_REBIRTH then break end
                            if b.Name:lower():find("worker") then
                                smartBuy(remote, folder, b.Name)
                            end
                        end
                    end
                end
            end

            -- Farm to $150k
            while running and autoFarm and getMoney() < MONEY_TO_REBIRTH do
                if campActive then task.wait(0.5) else
                    setStatus("Farming $150k... $" .. tostring(getMoney()) .. " / $150,000")
                    task.wait(2); teleportToCollector()
                end
            end

            -- Attempt rebirth
            local rebirthRemote = tycoon:WaitForChild("Rebirth", 10)
            if not rebirthRemote then
                warn("[AutoFarm] Rebirth remote not found!")
                task.wait(3)
                continue
            end

            local rebirthDone = false
            while running and autoFarm and not rebirthDone do
                if campActive then
                    setStatus("Camp active - rebirth paused...")
                    task.wait(0.5)
                    continue
                end

                setStatus("Attempting rebirth...")
                local ok, result = pcall(function() return rebirthRemote:InvokeServer() end)
                print("[AutoFarm] Rebirth result:", ok, result)

                if ok and result ~= false then
                    print("[AutoFarm] Rebirth successful!")
                    rebirthDone = true
                    task.wait(5)
                else
                    warn("[AutoFarm] Rebirth false - buying FREE + all buttons then waiting $150k...")
                    if not campActive then buyFreeButtons(remote, folder) end
                    for _, b in ipairs(folder:GetChildren()) do
                        if not running or not autoFarm or campActive then break end
                        fireRemote(remote, b.Name); task.wait(BUY_DELAY)
                    end
                    while running and autoFarm and getMoney() < MONEY_TO_REBIRTH do
                        if campActive then task.wait(0.5) else
                            task.wait(2); teleportToCollector()
                            setStatus("Farming $150k... $" .. tostring(getMoney()) .. " / $150,000")
                        end
                    end
                    print("[AutoFarm] $150k hit - retrying rebirth...")
                end
            end

            -- After successful rebirth, loop restarts and falls into the >=1 branch
            continue
        end

        -- ── rebirths >= 1: Buy buttons to Manual then AFK ──
        -- First check if AutoEquipWeapon already exists
        if getAfkPart() then
            print("[Farm] AutoEquipWeapon found - switching to AFK mode")
            afkMode = true
            continue
        end

        -- AutoEquipWeapon not found yet: buy buttons until Manual appears
        if not manualBought then
            -- Rescan loop: buy priority/all buttons, but buy Manual the INSTANT it appears
            local emptyPasses = 0
            while running and autoFarm and not campActive and not manualBought and emptyPasses < EMPTY_PASSES do
                -- Check for Manual first — buy it immediately if present
                if folder:FindFirstChild(STOP_AT_BUTTON) then
                    setStatus("Buying Manual immediately...")
                    smartBuy(remote, folder, STOP_AT_BUTTON)
                    manualBought = true
                    print("[Farm] Manual bought - checking for AutoEquipWeapon")
                    break
                end

                -- Check what's available
                local hasPriority = false
                for _, name in ipairs(PRIORITY) do
                    if folder:FindFirstChild(name) then hasPriority = true break end
                end
                local hasAny = #folder:GetChildren() > 0

                if not hasAny then
                    emptyPasses = emptyPasses + 1
                    setStatus("No buttons found, waiting... (" .. emptyPasses .. "/" .. EMPTY_PASSES .. ")")
                    task.wait(2)
                else
                    emptyPasses = 0
                    if hasPriority then
                        setStatus("Buying priority buttons...")
                        for _, name in ipairs(PRIORITY) do
                            if not running or not autoFarm or campActive then break end
                            -- Check for Manual mid-loop too
                            if folder:FindFirstChild(STOP_AT_BUTTON) then break end
                            if SKIP_BUTTONS[name] then continue end  -- skip blocked buttons
                            if folder:FindFirstChild(name) then
                                smartBuy(remote, folder, name)
                            end
                        end
                    else
                        -- No priority buttons — buy everything in folder (Manual check at top next pass)
                        setStatus("Buying all available buttons...")
                        for _, b in ipairs(folder:GetChildren()) do
                            if not running or not autoFarm or campActive then break end
                            if b.Name == STOP_AT_BUTTON then break end  -- let loop top handle it
                            if SKIP_BUTTONS[b.Name] then continue end   -- skip blocked buttons
                            smartBuy(remote, folder, b.Name)
                        end
                    end
                end
            end
        else
            -- Manual bought - poll for AFK part
            setStatus("Waiting for AFK station to appear...")
            task.wait(3)
            if getAfkPart() then
                print("[Farm] AutoEquipWeapon appeared - switching to AFK mode")
                afkMode = true
            end
        end
    end
end)

