-- ──────────────────────────────────────────────────────────
--  STALL WATCHDOG — re-teleports to collector if money
--  stops increasing for 30s while in farm mode (not AFK)
-- ──────────────────────────────────────────────────────────
task.spawn(function()
    local STALL_TIMEOUT = 30  -- seconds before we consider money stalled
    local lastMoney     = getMoney()
    local lastChange    = tick()

    while running do
        task.wait(5)
        if not autoFarm or afkMode or campActive then
            -- Reset timer whenever not farming so we don't false-trigger
            lastMoney  = getMoney()
            lastChange = tick()
            continue
        end

        local now   = tick()
        local money = getMoney()

        if money ~= lastMoney then
            -- Money changed — reset stall timer
            lastMoney  = money
            lastChange = now
        elseif now - lastChange >= STALL_TIMEOUT then
            -- Money stuck for too long — snap back to collector
            warn("[Watchdog] Money stalled for " .. math.floor(now - lastChange) .. "s — re-teleporting to collector")
            setStatus("Watchdog: money stalled — re-teleporting!")
            teleportToCollector()
            lastChange = now  -- reset so we don't spam
        end
    end
end)

-- ──────────────────────────────────────────────────────────
--  CAMP WATCHER LOOP
-- ──────────────────────────────────────────────────────────
task.spawn(function()
    while running do
        task.wait(0.5)
        local tycoon = getTycoon()
        if not tycoon then campActive = false continue end
        local campsFolder = tycoon:FindFirstChild("Camps")
        if not campsFolder then campActive = false continue end
        local camps = campsFolder:GetChildren()

        if #camps == 0 then
            if campActive then
                campActive = false
                campLbl.Text = ""
                print("[Camp] All camps cleared - teleporting back to collector")
                teleportToCollector()
            end
            continue
        end

        -- Camp exists — take full control of player position
        campActive = true
        local camp = camps[1]
        campLbl.Text = "Camp: " .. camp.Name
        setStatus("Clearing camp: " .. camp.Name)

        local campBtn = camp:FindFirstChild("Button")
        if campBtn then
            local part
            if campBtn:IsA("BasePart") then
                part = campBtn
            else
                part = campBtn:FindFirstChildWhichIsA("BasePart", true)
                if not part then part = camp:FindFirstChildWhichIsA("BasePart", true) end
            end
            local hrp = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hrp and part then
                print("[Camp] Teleporting to", camp.Name, "part:", part.Name)
                hrp.CFrame = part.CFrame + Vector3.new(0, 5, 0)
            else
                warn("[Camp] Could not find HRP or part for", camp.Name)
            end
        else
            warn("[Camp] No Button child in", camp.Name)
            campLbl.Text = "Camp: " .. camp.Name .. " (no btn)"
        end
    end
end)

